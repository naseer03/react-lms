# ─────────────────────────────────────────────
# LMS Platform — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=5000
CLIENT_URL=https://yourdomain.com
APP_URL=https://yourdomain.com
APP_NAME=LMS Platform
ENABLE_CRON=true

# MongoDB
MONGO_URI=mongodb://localhost:27017/lms_db
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/lms_db

# JWT Secrets (minimum 32 random characters each)
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (Gmail / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password
EMAIL_FROM=LMS Platform <your_email@gmail.com>

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=2147483648

# Google Drive Backup
# Guide: https://developers.google.com/drive/api/quickstart/nodejs
GOOGLE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_oauth_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_for_backups
